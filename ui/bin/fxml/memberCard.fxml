<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>

<fx:root alignment="CENTER_LEFT" minHeight="130.0" prefWidth="300.0" spacing="15.0" style="-fx-background-color: -card-blue; -fx-background-radius: 18; -fx-padding: 15;" stylesheets="@../styles/styles.css" type="HBox" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <effect>
      <DropShadow height="10.0" radius="4.5" width="10.0" />
   </effect>
   <children>
      <ImageView fx:id="pfp" fitHeight="80.0" fitWidth="80.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../assets/bilclubspfp.jpg" />
         </image>
         <effect>
            <DropShadow>
               <color>
                  <Color opacity="0.38" />
               </color>
            </DropShadow>
         </effect>
      </ImageView>
      <VBox alignment="CENTER_LEFT" spacing="8.0" HBox.hgrow="ALWAYS">
         <children>
            <Label fx:id="namelbl" style="-fx-text-fill: -text-color;" text="Member name" wrapText="true">
               <font>
                  <Font name="Arial Bold" size="18.0" />
               </font>
            </Label>
            <Label fx:id="majorlbl" style="-fx-text-fill: -primary-color; -fx-font-weight: bold; -fx-opacity: 0.9;" text="Major">
               <font>
                  <Font name="Arial" size="13.0" />
               </font>
            </Label>
            <Region VBox.vgrow="ALWAYS" />
            <HBox alignment="BOTTOM_RIGHT">
               <children>
                  <Button fx:id="banBtn" mnemonicParsing="false" prefHeight="26.0" prefWidth="70.0" style="-fx-background-color: -signout-red; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;" text="Ban" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
   <styleClass>
      <String fx:value="button" />
      <String fx:value="club-card" />
   </styleClass>
</fx:root>
